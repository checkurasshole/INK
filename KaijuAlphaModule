local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService      = game:GetService("HttpService")

local localPlayer = Players.LocalPlayer
local Camera      = workspace.CurrentCamera

local Module = {}

Module.Config = {
    FlyEnabled   = false,
    FlyEnabled2  = false,
    FlyMode      = "PC",
    Speed        = 22,
    Acceleration = true,
    AccelRate    = 0.8,
    MaxAccel     = 1.5,
    currentAccel = 1.0,
    AutoSpawn    = true,
}

local savedCameraCF  = nil
local savedPlayerPos = nil
local isSelfSetting  = false

local function getChar() return localPlayer.Character end
local function getHRP()  local c = getChar(); return c and c:FindFirstChild("HumanoidRootPart") end
local function getHum()  local c = getChar(); return c and c:FindFirstChildWhichIsA("Humanoid") end

Module.getChar = getChar
Module.getHRP = getHRP
Module.getHum = getHum

local function getSelectedKaiju()
    local ls = localPlayer:FindFirstChild("leaderstats")
    local kv = ls and ls:FindFirstChild("Kaiju")
    return kv and kv.Value or ""
end

Module.getSelectedKaiju = getSelectedKaiju

local conns      = {}
local conns2     = {}
local desiredCF  = nil
local desiredCF2 = nil
local currentVel = Vector3.new(0,0,0)

local lastSafePos  = nil
local prevHRPPos   = nil
local antiTPReady  = false
local isSpawning   = false
local ANTI_TP_DIST = 45

local espRemovalConn = nil

local function removeESP(character)
    if not character then return end
    for _, obj in ipairs(character:GetDescendants()) do
        if obj:IsA("Highlight") or obj:IsA("SelectionBox") or obj:IsA("SelectionSphere") 
        or obj:IsA("BoxHandleAdornment") or obj:IsA("SphereHandleAdornment") then
            obj:Destroy()
        end
    end
end

local function startESPRemoval(character)
    if espRemovalConn then
        espRemovalConn:Disconnect()
    end
    
    if not character then return end
    
    removeESP(character)
    
    character.DescendantAdded:Connect(function(obj)
        if obj:IsA("Highlight") or obj:IsA("SelectionBox") or obj:IsA("SelectionSphere")
        or obj:IsA("BoxHandleAdornment") or obj:IsA("SphereHandleAdornment") then
            obj:Destroy()
        end
    end)
    
    espRemovalConn = RunService.Heartbeat:Connect(function()
        removeESP(character)
    end)
end

local function beginSpawn()
    isSpawning  = true
    antiTPReady = false
    task.delay(3.5, function()
        isSpawning = false
        local hrp = getHRP()
        if hrp then
            lastSafePos = hrp.Position
            prevHRPPos  = hrp.Position
        end
        antiTPReady = true
    end)
end

localPlayer.CharacterRemoving:Connect(function()
    savedCameraCF = Camera.CFrame
    local hrp = getHRP()
    if hrp then savedPlayerPos = hrp.Position end
end)

localPlayer.CharacterAdded:Connect(function(char)
    antiTPReady = false
    isSpawning  = false
    lastSafePos = nil
    prevHRPPos  = nil

    task.spawn(function()
        task.wait(0.1)
        startESPRemoval(char)
    end)

    if savedCameraCF then
        Camera.CameraType = Enum.CameraType.Scriptable
        Camera.CFrame     = savedCameraCF
        local lockConn
        lockConn = RunService.RenderStepped:Connect(function()
            Camera.CameraType = Enum.CameraType.Scriptable
            Camera.CFrame     = savedCameraCF
        end)
        local hum = char:WaitForChild("Humanoid", 10)
        local hrp = char:WaitForChild("HumanoidRootPart", 10)
        if not hum or not hrp then
            lockConn:Disconnect()
        else
            task.wait(0.3)
            lockConn:Disconnect()
            Camera.CameraSubject = hum
            Camera.CameraType    = Enum.CameraType.Custom
        end
    end

    if savedPlayerPos then
        local hrp = char:WaitForChild("HumanoidRootPart", 10)
        if hrp then
            task.wait(0.5)
            isSelfSetting = true
            hrp.CFrame = CFrame.new(savedPlayerPos)
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
            isSelfSetting = false
        end
    end

    local hrp = char:WaitForChild("HumanoidRootPart", 10)
    if not hrp then return end
    task.wait(2)
    lastSafePos = hrp.Position
    prevHRPPos  = hrp.Position
    antiTPReady = true
end)

RunService.Heartbeat:Connect(function()
    local hrp = getHRP()
    if not hrp or isSelfSetting then return end

    local currentPos = hrp.Position

    if Module.Config.FlyEnabled and desiredCF then
        if (currentPos - desiredCF.Position).Magnitude > 6 then
            isSelfSetting = true
            hrp.CFrame = desiredCF
            hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
            isSelfSetting = false
        end
        prevHRPPos = hrp.Position
        return
    end

    if Module.Config.FlyEnabled2 and desiredCF2 then
        if (currentPos - desiredCF2.Position).Magnitude > 6 then
            isSelfSetting = true
            hrp.CFrame = desiredCF2
            hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
            isSelfSetting = false
        end
        prevHRPPos = hrp.Position
        return
    end

    if isSpawning then
        prevHRPPos = currentPos
        return
    end

    if antiTPReady and prevHRPPos and lastSafePos then
        local frameDelta = (currentPos - prevHRPPos).Magnitude
        if frameDelta > ANTI_TP_DIST then
            isSelfSetting = true
            hrp.CFrame    = CFrame.new(lastSafePos)
            hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
            isSelfSetting = false
            prevHRPPos = lastSafePos
            return
        else
            lastSafePos = currentPos
        end
    end

    prevHRPPos = currentPos
end)

local function disconnectAll()
    for _, c in ipairs(conns) do c:Disconnect() end
    conns = {}
end

local function disconnectAll2()
    for _, c in ipairs(conns2) do c:Disconnect() end
    conns2 = {}
end

function Module.stopFly()
    Module.Config.FlyEnabled = false
    disconnectAll()
    desiredCF  = nil
    currentVel = Vector3.new(0,0,0)
    local hum = getHum()
    if hum then
        hum.WalkSpeed = 16
        hum:ChangeState(Enum.HumanoidStateType.GettingUp)
    end
end

function Module.stopFly2()
    Module.Config.FlyEnabled2 = false
    disconnectAll2()
    desiredCF2 = nil
end

function Module.startFly()
    Module.stopFly()
    Module.Config.FlyEnabled   = true
    Module.Config.currentAccel = 1.0

    conns[#conns+1] = RunService.Stepped:Connect(function()
        if not Module.Config.FlyEnabled then return end
        local hrp = getHRP()
        local h   = getHum()
        if not hrp or not h then return end
        h:ChangeState(Enum.HumanoidStateType.Running)
        isSelfSetting = true
        hrp.AssemblyLinearVelocity = currentVel
        isSelfSetting = false
    end)

    if Module.Config.FlyMode == "PC" then
        conns[#conns+1] = RunService.RenderStepped:Connect(function(dt)
            if not Module.Config.FlyEnabled then return end
            local hrp = getHRP()
            if not hrp then return end
            local h = getHum()
            if h then h.WalkSpeed = Module.Config.Speed end

            local camCF    = Camera.CFrame
            local moveDir  = Vector3.new(0,0,0)
            local isMoving = false

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += camCF.LookVector;  isMoving = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= camCF.LookVector;  isMoving = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= camCF.RightVector; isMoving = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += camCF.RightVector; isMoving = true end
            if UserInputService:IsKeyDown(Enum.KeyCode.E) or UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                moveDir += Vector3.new(0,1,0); isMoving = true
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Q) then
                moveDir -= Vector3.new(0,1,0); isMoving = true
            end

            if Module.Config.Acceleration then
                if isMoving then
                    Module.Config.currentAccel = math.min(Module.Config.currentAccel + Module.Config.AccelRate * dt, Module.Config.MaxAccel)
                else
                    Module.Config.currentAccel = math.max(Module.Config.currentAccel - Module.Config.AccelRate * dt * 2, 1.0)
                end
            else
                Module.Config.currentAccel = 1.0
            end

            local spd       = Module.Config.Speed * (Module.Config.Acceleration and Module.Config.currentAccel or 1.0)
            local targetVel = (isMoving and moveDir.Magnitude > 0)
                and moveDir.Unit * spd
                or Vector3.new(0,0,0)

            currentVel = currentVel:Lerp(targetVel, math.min(dt * 10, 1))

            if isMoving and moveDir.Magnitude > 0 then
                local flatDir = Vector3.new(moveDir.X, 0, moveDir.Z)
                local tilt    = -math.rad(15) * (currentVel.Magnitude / spd)
                if flatDir.Magnitude > 0.01 then
                    local targetCF = CFrame.new(hrp.Position, hrp.Position + flatDir) * CFrame.Angles(tilt, 0, 0)
                    isSelfSetting = true
                    hrp.CFrame = hrp.CFrame:Lerp(targetCF + (hrp.Position - targetCF.Position), dt * 8)
                    isSelfSetting = false
                end
            end

            isSelfSetting = true
            desiredCF = hrp.CFrame
            isSelfSetting = false
        end)
    else
        conns[#conns+1] = RunService.RenderStepped:Connect(function(dt)
            if not Module.Config.FlyEnabled then return end
            local hrp = getHRP()
            if not hrp then return end
            local h = getHum()
            if h then h.WalkSpeed = Module.Config.Speed end
            local lookDir = Camera.CFrame.LookVector
            currentVel = currentVel:Lerp(lookDir.Unit * Module.Config.Speed, math.min(dt * 6, 1))
            isSelfSetting = true
            hrp.CFrame = hrp.CFrame:Lerp(
                CFrame.new(hrp.Position, hrp.Position + lookDir) * CFrame.Angles(-math.rad(10), 0, 0),
                dt * 6
            )
            desiredCF = hrp.CFrame
            isSelfSetting = false
        end)
    end
end

function Module.startFly2()
    Module.stopFly2()
    Module.Config.FlyEnabled2 = true

    conns2[#conns2+1] = RunService.RenderStepped:Connect(function()
        if not Module.Config.FlyEnabled2 then return end
        if Module.Config.FlyEnabled then return end
        local hrp = getHRP()
        if not hrp then return end
        isSelfSetting = true
        desiredCF2 = hrp.CFrame
        isSelfSetting = false
    end)
end

local FireServer  = ReplicatedStorage:WaitForChild("Remotes", 9e9):WaitForChild("FireServer", 9e9)
local ClientEvent = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ClientEvent")

function Module.fireSpawn()
    beginSpawn()
    FireServer:FireServer("Spawn", getSelectedKaiju(), "Tokyo")
end

ClientEvent.OnClientEvent:Connect(function(eventType, skillName, duration)
    if eventType ~= "Cooldown" then return end
    local cd = tonumber(duration) or 0
    if cd <= 0 then return end
    if not Module.Config.AutoSpawn then return end
    local char = localPlayer.Character
    local hum  = char and char:FindFirstChildWhichIsA("Humanoid")
    local anim = hum and hum:FindFirstChildWhichIsA("Animator")
    if anim then
        local attackTrack = nil
        for _, track in ipairs(anim:GetPlayingAnimationTracks()) do
            local p = track.Priority
            if p == Enum.AnimationPriority.Action or p == Enum.AnimationPriority.Action2
            or p == Enum.AnimationPriority.Action3 or p == Enum.AnimationPriority.Action4 then
                attackTrack = track; break
            end
        end
        if attackTrack then
            attackTrack.Stopped:Once(function() task.delay(0.1, Module.fireSpawn) end)
        else
            task.delay(0.5, Module.fireSpawn)
        end
    else
        Module.fireSpawn()
    end
end)

function Module.init()
    if localPlayer.Character then
        startESPRemoval(localPlayer.Character)
    end

    Module.startFly2()
    localPlayer.CharacterAdded:Connect(function()
        task.wait(2.5)
        Module.startFly2()
    end)

    UserInputService.InputBegan:Connect(function(input, gp)
        if gp then return end
        if input.KeyCode == Enum.KeyCode.F then
            if Module.Config.FlyEnabled then Module.stopFly() else Module.startFly() end
        end
    end)
end

return Module