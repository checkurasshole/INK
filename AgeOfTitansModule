local Module = {}

local MarketplaceService = game:GetService("MarketplaceService")
local Players            = game:GetService("Players")
local RunService         = game:GetService("RunService")
local TweenService       = game:GetService("TweenService")
local UserInputService   = game:GetService("UserInputService")

Module.setthreadidentity = set_thread_identity or setthreadcaps or setthreadidentity

Module.LocalPlayer = Players.LocalPlayer

Module.products = {
    { name = "Big Donation (100 R$)", id = 1595847811 },
    { name = "Inf Shards",            id = 3539271502 },
    { name = "Multiplied XP",         id = 3442717108 },
}

Module.productNames = {}
for _, p in ipairs(Module.products) do
    table.insert(Module.productNames, p.name)
end

Module.selectedProduct = Module.products[1]
Module.espConns        = {}
Module.flightBody      = {}
Module.heartbeatConn   = nil

function Module.elevate()
    pcall(Module.setthreadidentity, 7)
end

function Module.notify(Library, t, d)
    Library:Notify({Title=t, Description=d, Time=4})
end

function Module.cleanupFlight()
    for _, obj in pairs(Module.flightBody) do
        pcall(function() obj:Destroy() end)
    end
    Module.flightBody = {}
    local char = Module.LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand = false end
end

function Module.setupFlight()
    Module.cleanupFlight()
    local char = Module.LocalPlayer.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if not (char and hrp and hum) then return end
    hum.PlatformStand   = true
    local bv            = Instance.new("BodyVelocity")
    bv.Velocity         = Vector3.zero
    bv.MaxForce         = Vector3.new(1e5, 1e5, 1e5)
    bv.Parent           = hrp
    local bg            = Instance.new("BodyGyro")
    bg.MaxTorque        = Vector3.new(1e5, 1e5, 1e5)
    bg.D                = 100
    bg.CFrame           = hrp.CFrame
    bg.Parent           = hrp
    Module.flightBody.bv = bv
    Module.flightBody.bg = bg
end

function Module.getPlayerNames()
    local names = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Module.LocalPlayer then table.insert(names, p.Name) end
    end
    if #names == 0 then table.insert(names, "(no players)") end
    return names
end

function Module.applyESP(char)
    if not char then return end
    local hl            = Instance.new("Highlight")
    hl.Name             = "_CW_ESP"
    hl.FillColor        = Color3.fromRGB(255, 40, 40)
    hl.OutlineColor     = Color3.fromRGB(255, 255, 255)
    hl.FillTransparency = 0.5
    hl.Parent           = char
end

function Module.removeESP()
    for _, c in pairs(Module.espConns) do pcall(function() c:Disconnect() end) end
    Module.espConns = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Module.LocalPlayer and p.Character then
            local hl = p.Character:FindFirstChild("_CW_ESP")
            if hl then hl:Destroy() end
        end
    end
end

function Module.enableESP()
    Module.removeESP()
    local function addPlayer(p)
        if p == Module.LocalPlayer then return end
        if p.Character then Module.applyESP(p.Character) end
        table.insert(Module.espConns, p.CharacterAdded:Connect(Module.applyESP))
    end
    for _, p in pairs(Players:GetPlayers()) do addPlayer(p) end
    table.insert(Module.espConns, Players.PlayerAdded:Connect(addPlayer))
end

function Module.fireProduct(Library, product)
    local ok, err = pcall(function()
        Module.elevate()
        MarketplaceService:SignalPromptProductPurchaseFinished(Module.LocalPlayer.UserId, product.id, true)
    end)
    if ok then Module.notify(Library, "Got It!", "You received: " .. product.name)
    else Module.notify(Library, "Failed", tostring(err)) end
end

function Module.fireAll(Library)
    for _, p in ipairs(Module.products) do
        pcall(function()
            Module.elevate()
            MarketplaceService:SignalPromptProductPurchaseFinished(Module.LocalPlayer.UserId, p.id, true)
        end)
        task.wait()
    end
    Module.notify(Library, "Done!", "Received all " .. #Module.products .. " items.")
end

function Module.startHeartbeat(Toggles, Options)
    Module.heartbeatConn = RunService.Heartbeat:Connect(function()
        local char = Module.LocalPlayer.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        local cam  = workspace.CurrentCamera

        if Toggles.SpeedEnabled.Value and hum then
            hum.WalkSpeed = Options.WalkSpeedVal.Value
        end

        if Toggles.FlightEnabled.Value then
            if not (Module.flightBody.bv and Module.flightBody.bv.Parent) then
                Module.setupFlight()
            end
            if hrp and Module.flightBody.bv and Module.flightBody.bg then
                local speed = Options.FlightSpeed.Value
                local mode  = Options.FlightMode.Value
                local dir   = Vector3.zero

                if mode == "Mobile (Camera Direction)" then
                    dir = cam.CFrame.LookVector
                else
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + cam.CFrame.LookVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - cam.CFrame.LookVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - cam.CFrame.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + cam.CFrame.RightVector end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space)      then dir = dir + Vector3.new(0,1,0) end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)  then dir = dir - Vector3.new(0,1,0) end
                end

                Module.flightBody.bv.Velocity = dir.Magnitude > 0 and dir.Unit * speed or Vector3.zero
                Module.flightBody.bg.CFrame   = hrp.CFrame
            end
        else
            if Module.flightBody.bv then Module.cleanupFlight() end
        end
    end)
end

function Module.unloadAll(Library, Toggles)
    getgenv().bbLoopSingle = false
    getgenv().bbLoopAll    = false

    if Toggles.FlightEnabled then Toggles.FlightEnabled:SetValue(false) end
    if Toggles.SpeedEnabled  then Toggles.SpeedEnabled:SetValue(false)  end
    if Toggles.PlayerESP     then Toggles.PlayerESP:SetValue(false)     end
    if Toggles.LoopSingle    then Toggles.LoopSingle:SetValue(false)    end
    if Toggles.LoopAll       then Toggles.LoopAll:SetValue(false)       end

    Module.cleanupFlight()
    Module.removeESP()

    local char = Module.LocalPlayer.Character
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if hum then hum.WalkSpeed = 16 end

    if Module.heartbeatConn then Module.heartbeatConn:Disconnect() end
end

