function Module.enableInfiniteJump()
    if infiniteJumpConn then return end
    infiniteJumpConn = UserInputService.JumpRequest:Connect(function()
        local char = player.Character
        local hum  = char and char:FindFirstChildOfClass("Humanoid")
        if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end)
end

function Module.disableInfiniteJump()
    if infiniteJumpConn then infiniteJumpConn:Disconnect(); infiniteJumpConn = nil end
end

function Module.enableNoclip()
    if noclipConn then return end
    noclipConn = RunService.Stepped:Connect(function()
        local char = player.Character
        if not char then return end
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end)
end

function Module.disableNoclip()
    if noclipConn then noclipConn:Disconnect(); noclipConn = nil end
    local char = player.Character
    if char then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = true end
        end
    end
end

function Module.enableAntiAFK()
    if getconnections then
        pcall(function()
            for _, connection in pairs(getconnections(player.Idled)) do
                if connection["Disable"] then
                    connection["Disable"](connection)
                elseif connection["Disconnect"] then
                    connection["Disconnect"](connection)
                end
            end
        end)
    end
    if not antiAFKConn then
        antiAFKConn = player.Idled:Connect(function()
            pcall(function()
                VirtualUser:CaptureController()
                VirtualUser:ClickButton2(Vector2.new())
            end)
        end)
    end
end

function Module.disableAntiAFK()
    if antiAFKConn then antiAFKConn:Disconnect(); antiAFKConn = nil end
end

function Module.enablePotatoMode()
    originalProperties = {
        GlobalShadows = Lighting.GlobalShadows,
        FogEnd        = Lighting.FogEnd,
        Brightness    = Lighting.Brightness,
    }
    Lighting.GlobalShadows = false
    Lighting.FogEnd        = 9e9
    Lighting.Brightness    = 1
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("Atmosphere") or effect:IsA("BlurEffect") or effect:IsA("DepthOfFieldEffect")
        or effect:IsA("ColorCorrectionEffect") or effect:IsA("SunRaysEffect") or effect:IsA("BloomEffect") then
            effect.Enabled = false
        end
    end
    pcall(function() workspace.Terrain.Decoration = false end)
end

function Module.disablePotatoMode()
    if originalProperties.GlobalShadows ~= nil then
        Lighting.GlobalShadows = originalProperties.GlobalShadows
        Lighting.FogEnd        = originalProperties.FogEnd
        Lighting.Brightness    = originalProperties.Brightness
    end
    for _, effect in pairs(Lighting:GetChildren()) do
        if effect:IsA("Atmosphere") or effect:IsA("BlurEffect") or effect:IsA("DepthOfFieldEffect")
        or effect:IsA("ColorCorrectionEffect") or effect:IsA("SunRaysEffect") or effect:IsA("BloomEffect") then
            effect.Enabled = true
        end
    end
    pcall(function() workspace.Terrain.Decoration = true end)
end

function Module.sendDiscordNotification(name, mutation, rarity)
    if not DiscordState.Enabled then return end
    if not DiscordState.WebhookURL or DiscordState.WebhookURL == "" then return end
    local key = (name or "?") .. "|" .. (mutation or "None") .. "|" .. (rarity or "?")
    local now = tick()
    if lastNotified[key] and (now - lastNotified[key]) < DiscordState.Cooldown then return end
    local shouldNotify = false
    local rarityActive = false
    for _, active in pairs(DiscordState.NotifyRarities) do
        if active then rarityActive = true; break end
    end
    local mutActive = false
    for _, active in pairs(DiscordState.NotifyMutations) do
        if active then mutActive = true; break end
    end
    if not rarityActive and not mutActive then return end
    if rarityActive then
        for rName, active in pairs(DiscordState.NotifyRarities) do
            if active then
                if rName == "Rainbow / Divine" then
                    if rarity and (rarity:lower() == "rainbow" or rarity:lower() == "divine") then shouldNotify = true end
                elseif rName == "OG / Demon" then
                    if rarity and (rarity:lower() == "og" or rarity:lower() == "demon") then shouldNotify = true end
                elseif rarity and rarity:lower() == rName:lower() then
                    shouldNotify = true
                end
            end
        end
    end
    if mutActive then
        for mName, active in pairs(DiscordState.NotifyMutations) do
            if active then
                if mName == "Normal" then
                    if not mutation or mutation == "None" then shouldNotify = true end
                elseif mutation and mutation:lower() == mName:lower() then
                    shouldNotify = true
                end
            end
        end
    end
    if not shouldNotify then return end
    lastNotified[key] = now
    local displayRarity = rarity or "Unknown"
    if displayRarity:lower() == "rainbow" or displayRarity:lower() == "divine" then
        displayRarity = "Rainbow / Divine"
    elseif displayRarity:lower() == "og" or displayRarity:lower() == "demon" then
        displayRarity = "OG / Demon"
    end
    local message = string.format(
        "@everyone\n🚨 **Pet Found!**\n🐾 **Name:** %s\n✨ **Mutation:** %s\n⭐ **Rarity:** %s\n👤 **Player:** %s",
        name or "Unknown",
        mutation or "None",
        displayRarity,
        player.Name
    )
    pcall(function()
        request({
            Url     = DiscordState.WebhookURL,
            Method  = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body    = HttpService:JSONEncode({ content = message, username = "COMBOWICK Alert" }),
        })
    end)
end

function Module.updateKickPanel(name, mutation, rarity, cash)
    if Module.LabelName then Module.LabelName:SetText(name ~= "Unknown" and ("Name: "..name) or "Name: —") end
    if Module.LabelMut  then Module.LabelMut:SetText("Mutation: "..(mutation or "None")) end
    local displayRarity = rarity or "Unknown"
    if displayRarity:lower() == "rainbow" or displayRarity:lower() == "divine" then
        displayRarity = "Rainbow / Divine"
    elseif displayRarity:lower() == "og" or displayRarity:lower() == "demon" then
        displayRarity = "OG / Demon"
    end
    if Module.LabelRar  then Module.LabelRar:SetText("Rarity: "..displayRarity) end
    if Module.LabelCash then Module.LabelCash:SetText("Cash: $"..(cash or "Unknown")) end
    Module.kickCount += 1
    if Module.LabelCount then Module.LabelCount:SetText("Kicks: "..Module.kickCount) end
    pcall(function()
        Module.sendDiscordNotification(name, mutation, rarity)
    end)
end

function Module.getCashRaw(name, level, mutation)
    local ok, base = pcall(EntitiesData.GetCostForUpgrade, name, 1)
    if not ok or not base then return nil end
    local levelMult = EntitiesData.CachedMultipliers[level] or 1
    local mutMult = 1
    if mutation and mutation ~= "None" then
        local ok2, buff = pcall(function() return MutationData.Buffs[mutation].Value end)
        if ok2 and buff then mutMult = buff end
    end
    local ok3, result = pcall(function() return base * levelMult * mutMult end)
    return ok3 and result or nil
end

function Module.watchKickEvent(remote)
    remote.OnClientEvent:Connect(function(...)
        local args         = { ... }
        local mutationData = args[2]
        local name, mutation, rarity, cash = "Unknown","None","Unknown","Unknown"
        pcall(function() name     = tostring(mutationData.Name)     end)
        pcall(function() mutation = tostring(mutationData.Mutation) end)
        pcall(function() rarity   = Module.getRarity(name)          end)
        pcall(function() cash     = Module.getCash(name, mutation)   end)
        lastPrediction = { name=name, mutation=mutation, rarity=rarity, cash=cash }
        Module.lastPrediction = lastPrediction
        Module.updateKickPanel(name, mutation, rarity, cash)
    end)
end

function Module.hookRemotes()
    local function findAndHook(parent)
        for _, v in pairs(parent:GetDescendants()) do
            if v.ClassName == "RemoteEvent" and v.Name == "rev_KickEvent" and not hooked[v] then
                hooked[v] = true
                Module.watchKickEvent(v)
            end
        end
    end
    findAndHook(ReplicatedStorage)
    findAndHook(workspace)
end

