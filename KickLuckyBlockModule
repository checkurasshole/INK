function Module.getRarity(name)
    local bestRarity, bestPriority = "Unknown", math.huge
    for rarity, pool in pairs(RarityData.BrainrotPool) do
        if type(pool) == "table" then
            for _, entry in pairs(pool) do
                if type(entry) == "table" and entry.Name == name then
                    local p = RARITY_PRIORITY[rarity] or math.huge
                    if p < bestPriority then bestPriority = p; bestRarity = rarity end
                end
            end
        end
    end
    return bestRarity
end

function Module.getCash(name, mutation)
    local ok, base = pcall(function() return EntitiesData.GetCostForUpgrade(name, 1) end)
    if ok and base then
        local mult = 1
        if mutation ~= "None" then
            local ok2, buff = pcall(function() return MutationData.Buffs[mutation].Value end)
            if ok2 and buff then mult = buff end
        end
        return tostring(base * mult) .. "/s"
    end
    return "Unknown"
end

function Module.ForcedTP(cf)
    local char = player.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.Velocity = Vector3.new(0,0,0); hrp.CFrame = cf end
end

function Module.getMyPlot()
    for _, plot in pairs(workspace.Plots:GetChildren()) do
        local dec = plot:FindFirstChild("Decorations")
        if dec then
            local po = dec:FindFirstChild("PlotOwner")
            if po then
                local g = po:FindFirstChild("OwnerGUI")
                if g then
                    local tl = g:FindFirstChild("TextLabel")
                    if tl and (tl.Text == player.Name or tl.Text == player.DisplayName) then
                        return plot
                    end
                end
            end
        end
    end
end

local function hasAnyActive(t)
    if not t then return false end
    for _, v in pairs(t) do if v then return true end end
    return false
end

function Module.mutationPassesKeep(pet)
    local f = State.KeepMutFilter
    if not hasAnyActive(f) then return true end
    for name, active in pairs(f) do
        if active then
            if name == "Normal" then
                local hasMut = false
                for _, desc in pairs(pet:GetDescendants()) do
                    for _, m in ipairs(KNOWN_MUTATIONS) do
                        if string.find(desc.Name:lower(), m) then hasMut = true; break end
                    end
                    if hasMut then break end
                end
                if not hasMut then return true end
            else
                for _, desc in pairs(pet:GetDescendants()) do
                    if string.find(desc.Name:lower(), name:lower()) then return true end
                end
            end
        end
    end
    return false
end

function Module.rarityPassesKeep(rarity)
    local f = State.KeepRarityFilter
    if not hasAnyActive(f) then return true end
    for name, active in pairs(f) do
        if active then
            if name == "Rainbow / Divine" then
                if rarity and (rarity:lower() == "rainbow" or rarity:lower() == "divine") then return true end
            elseif name == "OG / Demon" then
                if rarity and (rarity:lower() == "og" or rarity:lower() == "demon") then return true end
            elseif rarity and rarity:lower() == name:lower() then
                return true
            end
        end
    end
    return false
end

local function smoothFlyTo(hrp, hum, targetPos)
    local target = Vector3.new(targetPos.X, 3, targetPos.Z)
    hrp.Anchored = true
    while hrp and hum and hum.Health > 0 do
        local dt  = task.wait()
        local pos = hrp.Position
        local dir = (target - pos)
        if dir.Magnitude < 2 then hrp.CFrame = CFrame.new(target); break end
        local speed    = math.max(hum.WalkSpeed, 80)
        local moveDist = math.min(speed * dt, dir.Magnitude)
        hrp.CFrame = CFrame.new(pos + dir.Unit * moveDist)
    end
    if hrp and hrp.Parent then hrp.Anchored = false end
end

function Module.getPetMutation(pet)
    for _, child in pairs(pet:GetChildren()) do
        if MUTATIONS[child.Name:lower()] then
            return MUTATIONS[child.Name:lower()]
        end
    end
    return nil
end

function Module.slotHasPet(myPlot, slotIndex)
    if not myPlot then return false end
    local slots = myPlot:FindFirstChild("Slots")
    if not slots then return false end
    local slot = slots:FindFirstChild("Slot" .. slotIndex)
    if not slot then return false end
    local placed = slot:FindFirstChild("PlacedPart")
    if not placed then return false end
    for _, child in pairs(placed:GetChildren()) do
        if child:IsA("Model") then return true end
    end
    return false
end

function Module.buildSlotLabel(s)
    local mut = s.mutation and (" ["..s.mutation.."]") or ""
    return "Slot "..s.index..": "..s.petName..mut
end

function Module.scanSlots()
    if not State.AutoRefreshSlots then return end
    scannedSlots = {}
    Module.scannedSlots = scannedSlots
    local myPlot = Module.getMyPlot()
    if not myPlot then return end
    local slots = myPlot:FindFirstChild("Slots")
    if not slots then return end
    for i = 1, 30 do
        local slot = slots:FindFirstChild("Slot"..i)
        if slot then
            local placed = slot:FindFirstChild("PlacedPart")
            if placed then
                for _, pet in pairs(placed:GetChildren()) do
                    if pet:IsA("Model") then
                        local mut = Module.getPetMutation(pet)
                        table.insert(scannedSlots, {
                            index    = i,
                            petName  = pet.Name,
                            mutation = mut,
                        })
                    end
                end
            end
        end
    end
    if Module.upgradeDropdown then
        local newValues = {}
        for _, s in ipairs(scannedSlots) do
            table.insert(newValues, Module.buildSlotLabel(s))
        end
        if #newValues == 0 then newValues = { "No pets found" } end
        Module.upgradeDropdown:SetValues(newValues)
        if State.TargetUpgrade == 1 and scannedSlots[1] then
            Module.upgradeDropdown:SetValue(newValues[1])
            State.TargetUpgrade = scannedSlots[1].index
        end
    end
end

task.spawn(function()
    task.wait(2)
    pcall(Module.scanSlots)
    while true do
