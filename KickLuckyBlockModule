        pcall(Module.scanSlots)
    end
end)

function Module.startOofLoop()
    if State.OofLooping then return end
    State.OofLooping = true
    task.spawn(function()
        while State.OofLooping do
            pcall(function()
                local char = player.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                if root and root.Anchored then root.Anchored = false end
                for _, v in pairs(Players:GetPlayers()) do
                    if v.Character and v.Character:FindFirstChild("Head") then
                        for _, x in pairs(v.Character.Head:GetChildren()) do
                            if x:IsA("Sound") then
                                pcall(function() x.Playing = true end)
                            end
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
end

function Module.stopOofLoop()
    State.OofLooping = false
end

function Module.startAutoKick()
    tickID += 1
    local id = tickID
    task.spawn(function()
        while State.AutoKick and id == tickID do
            pcall(function()
                local char = player.Character
                local hrp  = char and char:FindFirstChild("HumanoidRootPart")
                local hum  = char and char:FindFirstChild("Humanoid")
                if not (hrp and hum and hum.Health > 0) then return end
                local kickPos = workspace:FindFirstChild("Areas") and workspace.Areas:FindFirstChild("KickReady")
                if not kickPos then return end
                local kickCF = kickPos:IsA("BasePart") and kickPos.CFrame or kickPos:GetPivot()
                Module.ForcedTP(kickCF + Vector3.new(0, 3, 0))
                task.wait(0.5)
                lastPrediction = { name=nil, mutation=nil, rarity=nil, cash=nil }
                Module.lastPrediction = lastPrediction
                local startPos      = hrp.Position
                local wasTeleported = false
                local HUD           = PlayerGui:FindFirstChild("HUD")
                for _ = 1, 150 do
                    task.wait(0.1)
                    if not char or not char.Parent or hum.Health <= 0 then return end
                    if (hrp.Position - startPos).Magnitude > 40 then wasTeleported = true; break end
                    local KB = HUD and HUD:FindFirstChild("KickButton")
                    if KB and KB.Visible then
                        Net.rev_KickEvent:FireServer(KICK_VALUES[State.KickMode] or 1)
                        task.wait(0.5)
                    end
                end
                if not wasTeleported then return end
                task.wait(0.8)
                local spawnedMonster = nil
                for _ = 1, 40 do
                    task.wait(0.2)
                    local best = 60
                    for _, obj in pairs(workspace.Debris:GetChildren()) do
                        if obj:IsA("Model") and obj.PrimaryPart then
                            local d = (obj.PrimaryPart.Position - hrp.Position).Magnitude
                            if d < best then best = d; spawnedMonster = obj end
                        end
                    end
                    if spawnedMonster then break end
                end
                if not spawnedMonster then return end
                task.wait(0.5)
                local mutOk  = Module.mutationPassesKeep(spawnedMonster)
                local rarity = lastPrediction.rarity
                if not rarity or rarity == "Unknown" then
                    local nameToCheck = (lastPrediction.name and lastPrediction.name ~= "Unknown")
                        and lastPrediction.name or spawnedMonster.Name
                    rarity = Module.getRarity(nameToCheck)
                end
                local rarityOk = Module.rarityPassesKeep(rarity)
                local zoneOk = true
                if State.ZoneFilter and next(State.ZoneFilter) ~= nil then
                    zoneOk = false
                    for zone, active in pairs(State.ZoneFilter) do
                        if active then
                            local z = workspace:FindFirstChild("Areas") and workspace.Areas:FindFirstChild(zone)
                            if z then zoneOk = true; break end
                        end
                    end
                end
                if mutOk and rarityOk and zoneOk then
                    smoothFlyTo(hrp, hum, kickCF.Position)
                end
            end)
            task.wait(0.4)
        end
    end)
end

function Module.startAutoCollect()
    task.spawn(function()
        local char = player.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not lockedPlot and hrp then
            local closestDist = math.huge
            for _, plot in pairs(workspace:WaitForChild("Plots"):GetChildren()) do
                if plot:IsA("Model") or plot:IsA("Folder") then
                    local d = (hrp.Position - plot:GetPivot().Position).Magnitude
                    if d < closestDist then closestDist = d; lockedPlot = plot end
                end
            end
        end
        while State.AutoCollect do
            pcall(function()
                if not lockedPlot then return end
                local buttonsFolder = lockedPlot:FindFirstChild("Buttons")
                if not buttonsFolder then return end
                for i = 1, 30 do
                    if not State.AutoCollect then break end
                    if not Module.slotHasPet(lockedPlot, i) then continue end
                    local slotPart = buttonsFolder:FindFirstChild("Slot" .. i)
                    if slotPart then
                        local targetCF
                        if slotPart:IsA("BasePart") then
                            targetCF = slotPart.CFrame
                        elseif slotPart:IsA("Model") and slotPart.PrimaryPart then
                            targetCF = slotPart.PrimaryPart.CFrame
                        elseif slotPart:FindFirstChildWhichIsA("BasePart") then
                            targetCF = slotPart:FindFirstChildWhichIsA("BasePart").CFrame
                        end
                        if targetCF then
                            Module.ForcedTP(targetCF + Vector3.new(0, 1.5, 0))
                            task.wait(0.1)
                            Net.rev_B_Collect:FireServer(i)
                        end
                    end
                end
            end)
            task.wait(1.5)
        end
    end)
end

